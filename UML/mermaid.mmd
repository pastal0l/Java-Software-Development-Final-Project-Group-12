classDiagram
    %% Core UI / Main Loop
    class Main {
        +main(String[] args)
    }
    class LobbyPanel {
        -JFrame frame
        -JTextField ipField
        +buildUI()
        +startSinglePlayer()
        +hostGame()
        +connectToServer()
    }
    class GamePanel {
        -double playerX
        -double playerY
        -double playerAngle
        -Renderer renderer
        +startGame()
        +mouseMoved()
        +requestFocusForInput()
    }
    
    %% Rendering & Audio
    class Renderer {
        -GamePanel game
        -BufferedImage screenBuffer
        -int[] screenPixels
        +drawScene(Graphics g)
        +drawAllMonsterSprites()
        +drawHUD(Graphics2D g)
    }
    class Textures {
        -int TEX_SIZE
        +int[][] createBrick()
        +int[][] createWood()
        +int[][] createStone()
        +int[][] createDoor()
    }
    class SoundPlayer {
        -Clip dingClip
        -Clip monsterClip
        -Clip footstepClip
        +playDing()
        +playFootstep()
        +playVictoryMusic()
    }

    %% Networking & Server Logic
    class GameServer {
        -int PORT
        -int currentLevel
        -LevelConfig config
        -int[][] map
        -List~Monster~ monsters
        -List~Ball~ balls
        -Door door
        +run()
        +loadLevel()
        +pushLevelData()
    }
    class NetworkClient {
        -Socket socket
        -PrintWriter writer
        -BufferedReader reader
        +readSetup()
        +readLoop()
        +parseState()
    }
    class MazeGenerator {
        +int[][] generateMaze()
        +carveMaze()
    }
    class Pathfinder {
        +List~Node~ findPath()
        +int getManhattanDistance()
        +List~Node~ retracePath()
    }

    %% Game Entities
    class Monster {
        -double x
        -double y
        -long lastPathCalculationTime
        -List~Pathfinder.Node~ currentPath
        +update()
        +followAStarPath()
        +getSprite()
    }
    class Door {
        -int tileX
        -int tileY
        -boolean open
        +open()
        +close()
    }
    class Ball {
        -double x
        -double y
    }
    class RemotePlayer {
        -double x
        -double y
        -double angle
    }

    %% Inheritance (Solid line, hollow arrow) & Implementation (Dotted line, hollow arrow)
    JPanel <|-- GamePanel
    JPanel <|-- LobbyPanel
    Runnable <|.. GameServer

    %% Associations: "Has-A" / Class Fields (Solid line, solid arrow)
    GamePanel --> Renderer : renderer
    Renderer --> GamePanel : game
    GameServer --> LevelConfig : config
    GameServer --> Monster : monsters
    GameServer --> Ball : balls
    GameServer --> Door : door

    %% Dependencies: "Uses-A" / Method Calls & Instantiation (Dotted line, solid arrow)
    Main ..> LobbyPanel : creates
    LobbyPanel ..> GamePanel : creates & transitions to
    LobbyPanel ..> GameServer : spawns (if hosting)
    LobbyPanel ..> NetworkClient : creates (if client)
    GamePanel ..> SoundPlayer : calls static audio methods
    Renderer ..> Textures : retrieves texture arrays
    GameServer ..> MazeGenerator : asks for map generation
    Monster ..> Pathfinder : requests route calculation